{
  "name": "path-of-titans-ecosystem-bot",
  "version": "0.1.0",
  "description": "Discord, RCON, economy, moderation, analytics, and event tooling for a Path of Titans community server.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "deploy": "node src/deploy-commands.js",
    "db:init": "node src/db/init.js",
    "check": "node --check src/index.js && node --check src/deploy-commands.js"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "node-cron": "^4.2.1",
    "rcon-client": "^4.2.5",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
